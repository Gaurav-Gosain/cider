# Shared VHS settings for every cider tape. Source with
#   Source "vhs/_common.tape"
# at the top of each individual tape so the look stays consistent.

Set Shell "bash"
Set FontSize 15
Set Width 1320
Set Height 760
Set FontFamily "JetBrainsMono Nerd Font Mono"
Set Theme "TokyoNight"
Set Padding 20
Set Margin 18
Set MarginFill "#FF60FF"
Set BorderRadius 10
Set WindowBar Colorful
Set WindowBarSize 36
Set TypingSpeed 30ms
Set Framerate 60
Set PlaybackSpeed 1.0
Set LoopOffset 5%
